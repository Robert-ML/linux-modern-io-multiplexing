MSG_SIZE ?= 2048
CDEFINES_COMMON ?=  -DDEFAULT_BUFFER_SIZE=$(MSG_SIZE)U -DSERVER_PORT=8080U -DSERVER_ADDRESS=\"127.0.0.1\" -DCLIENT_MODE=0

IO_URING_POLL_SQ ?= 0
CDEFINES_IO_URING ?= -DIO_URING_RING_SIZE=32768U -DIO_URING_RUN_IN_KERNEL_POLL_MODE=$(IO_URING_POLL_SQ)

CDEFINES_DEBUG ?= -DDEBUG -DLOG_LEVEL=LOG_DEBUG
CDEFINES_TEST ?= -DDEBUG -DLOG_LEVEL=LOG_INFO
CDEFINES_RELEASE ?= -DDEBUG -DLOG_LEVEL=LOG_WARNING
